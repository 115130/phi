{
  "name": "phi-pi",
  "displayName": "Phi-Pi AI Agent",
  "description": "Phi-Pi：将 Pi AI 编程助手完整移植到 VS Code。支持全会话连续性、实时流式输出、深度编辑器上下文集成。",
  "version": "0.1.0",
  "publisher": "pi",
  "icon": "assets/phi-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pi/phi-pi"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "type": "module",
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "pi",
    "agent",
    "phi"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "phi-pi-sidebar",
          "title": "Phi-Pi（φ）",
          "icon": "assets/phi-chat.svg"
        }
      ]
    },
    "views": {
      "phi-pi-sidebar": [
        {
          "type": "webview",
          "id": "phi-pi.chatView",
          "name": "Phi-Pi"
        }
      ]
    },
    "commands": [
      {
        "command": "phi-pi.openChat",
        "title": "Phi: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "phi-pi.addSelectionToChat",
        "title": "Phi: Add to Chat",
        "icon": "$(add)"
      },
      {
        "command": "phi-pi.addFileToChat",
        "title": "Phi: Add File to Chat",
        "icon": "$(add)"
      },
      {
        "command": "phi-pi.askAboutSelection",
        "title": "Phi: Ask About Selection",
        "icon": "$(sparkle)"
      },
      {
        "command": "phi-pi.newSession",
        "title": "Phi: New Session",
        "icon": "$(add)"
      },
      {
        "command": "phi-pi.abortSession",
        "title": "Phi: Abort Current Turn",
        "icon": "$(stop-circle)"
      },
      {
        "command": "phi-pi.login",
        "title": "Phi: Login",
        "icon": "$(sign-in)"
      },
      {
        "command": "phi-pi.logout",
        "title": "Phi: Logout",
        "icon": "$(sign-out)"
      },
      {
        "command": "phi-pi.addApiKey",
        "title": "Phi: Add API Key",
        "icon": "$(key)"
      },
      {
        "command": "phi-pi.removeApiKey",
        "title": "Phi-Pi: 删除 API 密钥",
        "icon": "$(trash)"
      },
      {
        "command": "phi-pi.openTree",
        "title": "Phi-Pi: 打开对话树",
        "icon": "$(git-branch)"
      }
    ],
    "keybindings": [
      {
        "command": "phi-pi.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "phi-pi.addSelectionToChat",
        "key": "ctrl+shift+=",
        "mac": "cmd+shift+=",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "phi-pi.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "phi-pi@1"
        }
      ],
      "explorer/context": [
        {
          "command": "phi-pi.addFileToChat",
          "when": "!explorerResourceIsFolder",
          "group": "phi-pi@1"
        }
      ]
    },
    "configuration": {
      "title": "Phi-Pi（φ）",
      "properties": {
        "phi.autoContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically send editor context (active file, selection) to Pi when opening the chat panel."
        },
        "phi.disabledExtensions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Pi extension IDs disabled in Phi. Managed by the Extensions section in Phi Settings."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build-num.mjs && pnpm run build:ext && pnpm run build:web",
    "build:ext": "node scripts/build-ext.mjs",
    "build:web": "esbuild public/app.js --bundle --outdir=dist/public --format=esm && cp public/style.css dist/public/style.css",
    "watch": "node scripts/build-num.mjs && concurrently \"pnpm run build:ext -- --watch\" \"esbuild public/app.js --bundle --outdir=dist/public --format=esm --watch\"",
    "watch:ext": "node scripts/build-num.mjs && node scripts/build-ext.mjs --watch",
    "watch:web": "esbuild public/app.js --bundle --outdir=dist/public --format=esm --watch",
    "typecheck": "tsc --noEmit",
    "package": "pnpm run build && pnpm exec vsce package --no-dependencies",
    "release": "node scripts/release.mjs",
    "release:status": "node scripts/release.mjs status",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.24.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.20.0",
    "ovsx": "^0.10.10",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@google/genai": "1.46.0",
    "@earendil-works/pi-agent-core": "file:./pi-sdk/agent",
    "@earendil-works/pi-ai": "file:./pi-sdk/ai",
    "@earendil-works/pi-coding-agent": "file:./pi-sdk/coding-agent",
    "@earendil-works/pi-tui": "file:./pi-sdk/tui",
    "shiki": "^4.0.2"
  }
}
